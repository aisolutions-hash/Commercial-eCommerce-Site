# Database - Use Neon for production
# Get connection string from: https://console.neon.tech
DATABASE_URL=postgresql+asyncpg://user:password@ep-cool-name.us-east-1.neon.tech/kalisoft_ecommerce?sslmode=require

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# App
APP_URL=http://localhost:3000

# Error Tracking (Optional)
SENTRY_DSN=

# Email Configuration (Optional - for contact form)
CONTACT_NOTIFY_EMAIL=admin@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Neon Database (Production)
# No additional config needed - use DATABASE_URL above
# Neon handles all connection pooling automatically
